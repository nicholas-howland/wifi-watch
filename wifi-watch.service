[Unit]
Description=Wi-Fi Watch Network Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/wifi-watch
Environment="WIFI_WATCH_NETWORK=192.168.1.0/24"
Environment="WIFI_WATCH_INTERVAL=15"
Environment="WIFI_WATCH_WEB_HOST=127.0.0.1"
Environment="WIFI_WATCH_WEB_PORT=5000"
ExecStart=/opt/wifi-watch/venv/bin/python3.13 /opt/wifi-watch/app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
